# Application
APP_ENV=development                    # development | production
SECRET_KEY=your-jwt-secret-min-32-chars-change-this
ALLOWED_ORIGINS=http://localhost:5173

# Database
DATABASE_URL=sqlite+aiosqlite:///./fairsight.db  # dev
# DATABASE_URL=postgresql+asyncpg://user:pass@host/db  # prod

# Google Gemini AI
GOOGLE_API_KEY=your-google-api-key-here
GEMINI_MODEL=gemini-2.0-flash
GEMINI_MAX_TOKENS=1500

# Firebase (path to service account JSON)
FIREBASE_CREDENTIALS_PATH=./firebase-service-account.json

# File limits
MAX_UPLOAD_SIZE_MB=50
MAX_ROWS=500000
